def obfuscate_string(s):
    """Verschleiert Strings mit Base64 und XOR."""
    encoded = base64.b64encode(s.encode()).decode()
    xored = ''.join(chr(ord(c) ^ 0x1F) for c in encoded)
    return xored

def deobfuscate_string(s):
    """Entschlüsselt verschleierte Strings."""
    decoded = ''.join(chr(ord(c) ^ 0x1F) for c in s)
    return base64.b64decode(decoded).decode()

def xor_encrypt(data, key=0x1F):
    """Encrypt strings with XOR and base64."""
    return base64.b64encode(''.join(chr(ord(c) ^ key) for c in data).encode()).decode()

def xor_decrypt(data, key=0x1F):
    """Decrypt strings at runtime."""
    decoded = base64.b64decode(data).decode()
    return ''.join(chr(ord(c) ^ key) for c in decoded)

